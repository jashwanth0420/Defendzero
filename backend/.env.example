# DefendZero Backend Configuration

# Server
PORT=5000
NODE_ENV=development

# Database (PostgreSQL)
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/defendzero

# Cache & Queue (Redis)
# Format: redis://[password]@[host]:[port]/[database]
REDIS_URL=redis://localhost:6379

# Authentication
# Generate a strong secret: openssl rand -base64 32
# DON'T hardcode in production - use secrets manager
JWT_SECRET=super_secret_defendzero_key_change_in_production_12345

# Google OAuth (Optional)
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Firebase Cloud Messaging (Optional)
# Get from: https://console.firebase.google.com/
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_API_KEY=your_firebase_api_key

# Logging
LOG_LEVEL=debug
