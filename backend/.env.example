# DefendZero Backend Configuration

# Server
PORT=5000
NODE_ENV=development

# Database (PostgreSQL)
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/defendzero

# Authentication
# Generate a strong secret: openssl rand -base64 32
# DON'T hardcode in production - use secrets manager
JWT_SECRET=super_secret_defendzero_key_change_in_production_12345

# Google OAuth (Optional)
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Firebase Cloud Messaging (Optional)
# Get from: https://console.firebase.google.com/
FIREBASE_PROJECT_ID=defendzero-2ab78
FIREBASE_API_KEY=AIzaSyC9SIiKKhjJlSqynIa8OqEOwp6TwW8o4fQ

# Logging
LOG_LEVEL=debug

# External API Timeout (ms)
RXNAV_TIMEOUT_MS=4000
OPENFDA_TIMEOUT_MS=4000
DAILYMED_TIMEOUT_MS=4000
